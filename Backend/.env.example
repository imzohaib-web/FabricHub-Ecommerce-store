# Port number for the Express server to run on
PORT=5000

# Environment mode (development, production, test)
NODE_ENV=development

# MongoDB connection string URI
MONGO_URI=mongodb://localhost:27017/fabric-store

# JSON Web Token config
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=7d

# Cloudinary credentials for product/category image uploads
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Nodemailer SMTP server credentials for sending emails (e.g. order confirmation, admin alerts)
EMAIL_HOST=smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_SECURE=false
EMAIL_USER=your_smtp_username
EMAIL_PASS=your_smtp_password
EMAIL_FROM=noreply@fabrichub.com
